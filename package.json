{
  "name": "tech-hub-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx lib/seed.mts",
    "seed:force": "tsx lib/seed.mts --force",
    "seed:check": "tsx lib/seed.mts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:all": "vitest run && vitest run --config vitest.config.integration.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "mongodb": "^7.2.0",
    "showdown": "^2.1.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
