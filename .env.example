# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=tech_hub_cms

# Session Secret (used by legacy cookie-based sessions)
SESSION_SECRET=change-this-to-a-random-secret

# Allowed CORS origins (comma-separated)
# Also reads from CLIENT_URL for backward compatibility
CORS_ORIGINS=http://localhost:3000,https://www.techteg.com

# OSS Configuration (Alibaba Cloud Object Storage)
OSS_REGION=oss-ap-southeast-5
OSS_ACCESS_KEY_ID=your-access-key
OSS_ACCESS_KEY_SECRET=your-access-secret
OSS_BUCKET=your-bucket-name
OSS_HTTPS=true
